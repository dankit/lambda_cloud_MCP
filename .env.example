# Copy to .env.local (or .env) in the project root.
# Next.js reads these for the UI; MCP loads the same files from process.cwd() (see TIER 2 note).

# =============================================================================
# TIER 1 — REQUIRED
# =============================================================================

# Authenticates server-side Lambda API calls when the UI/API key isn’t overridden.
LAMBDA_API_KEY=

# Absolute or relative path to the .pem for a public key registered in Lambda (UI ssh -i hint + MCP ssh_exec).
LAMBDA_SSH_PEM_PATH=

# =============================================================================
# TIER 2 — POKE / HTTP TRANSPORT (primary integration)
# FastMCP listens on 127.0.0.1; connect with: npx poke@latest tunnel http://127.0.0.1:8080/mcp
# Cursor users: comment out LAMBDA_MCP_TRANSPORT (stdio is the default when unset).
# =============================================================================

LAMBDA_MCP_TRANSPORT=http
LAMBDA_MCP_HTTP_PORT=8080
LAMBDA_MCP_HTTP_HOST=127.0.0.1
LAMBDA_MCP_HTTP_PATH=/mcp
# LAMBDA_MCP_HTTP_STATELESS=true
# Aliases (FastMCP CLI): FASTMCP_TRANSPORT=httpStream FASTMCP_PORT FASTMCP_HOST FASTMCP_ENDPOINT FASTMCP_STATELESS
# HTTP mode exposes tools without auth — bind 127.0.0.1 and tunnel; avoid 0.0.0.0 on untrusted networks.

# MCP dotenv: if LAMBDA_DOTENV_PATH is set in the shell / Cursor MCP env, only that file loads.
# Otherwise MCP loads .env.local then .env from process.cwd() (local wins). Already-set env wins (override: false).

# =============================================================================
# TIER 3 — WATCH / SNIPE (alerts shared by UI and MCP)
# Dev: if LAMBDA_WATCH_CONFIG_PATH is unset, Next uses cwd/.lambda/watch-config.json (gitignored).
# Production: set LAMBDA_WATCH_CONFIG_PATH to a writable JSON path.
# LAMBDA_WATCH_HTTP_URL is read by MCP only (GET); point at this app while it is running.
# =============================================================================

LAMBDA_WATCH_CONFIG_PATH=

# Example while Next is running locally: http://127.0.0.1:3000/api/watch-config
LAMBDA_WATCH_HTTP_URL=

# =============================================================================
# TIER 4 — OPTIONAL
# =============================================================================

# If set, after a successful launch the app POSTs launch details to Poke (Kitchen V2 API).
# POKE_API_KEY=

# Tool call debug — stderr-logs each tool's name, args, result, and duration.
# LAMBDA_MCP_DEBUG_TOOLS=true

# MCP SSH — connection options for ssh_exec and other SSH tools (defaults in src/lib/mcp-ssh.ts)
# LAMBDA_SSH_USER=ubuntu
# LAMBDA_SSH_PORT=22
# LAMBDA_SSH_TIMEOUT_MS=120000
# LAMBDA_SSH_DISABLE_HOST_KEY_CHECKING=true

# MCP training hints — documentation for agents via get_status.setup; not executed by this server.
# Names: docs/mcp-ssh-training-hints.md
# MCP_ENV_SETUP_COMMAND=
# MCP_TRAINING_START_COMMAND=
# MCP_TRAINING_STATUS_COMMAND=
# MCP_TRAINING_LOG_PATH=

# Securing /api/watch-config and production gating
# Dev NODE_ENV: watch-config routes work without LAMBDA_WATCH_ALLOW_SYNC.
# LAMBDA_WATCH_CONFIG_SYNC_SECRET=
# NEXT_PUBLIC_LAMBDA_WATCH_SYNC_SECRET=
# LAMBDA_WATCH_HTTP_SYNC_SECRET=
# LAMBDA_WATCH_ALLOW_SYNC=
