# Lambda Cloud API key from https://cloud.lambda.ai/api-keys
LAMBDA_API_KEY=

# Local path to the private key (.pem) matching a public key registered in Lambda (used in suggested SSH command only)
LAMBDA_SSH_PEM_PATH=

# MCP SSH defaults (used by lambda_ssh_run_allowed_command)
LAMBDA_SSH_USER=ubuntu
LAMBDA_SSH_PORT=22
LAMBDA_SSH_TIMEOUT_MS=120000
# Default true unless explicitly set to "false"
LAMBDA_SSH_DISABLE_HOST_KEY_CHECKING=true

# Optional project command hooks for strict allowlisted MCP SSH commands
MCP_TRAINING_START_COMMAND=
MCP_TRAINING_STATUS_COMMAND=
MCP_TRAINING_LOG_PATH=
MCP_SYSTEM_LOG_PATH=

# JSON file for watch list + Snipe prefs; Next POST /api/watch-config syncs UI here when set
LAMBDA_WATCH_CONFIG_PATH=

# MCP reads watch/snipe only via this GET URL, e.g. http://127.0.0.1:3000/api/watch-config (Next must be running; route reads LAMBDA_WATCH_CONFIG_PATH on the server)
LAMBDA_WATCH_HTTP_URL=

# Same value exposed to the browser for sync POST (only needed if server secret is set). Dev-only workflow.
NEXT_PUBLIC_LAMBDA_WATCH_SYNC_SECRET=

# Gate GET /api/watch-config + POST /api/watch-config when set; MCP GET uses this same value unless LAMBDA_WATCH_HTTP_SYNC_SECRET is set.
LAMBDA_WATCH_CONFIG_SYNC_SECRET=

# Override secret header only for MCP/client GET of LAMBDA_WATCH_HTTP_URL (optional)
LAMBDA_WATCH_HTTP_SYNC_SECRET=

# Set to "true" to allow GET /api/watch-config + POST outside development (dangerous unless the app is localhost-only).
LAMBDA_WATCH_ALLOW_SYNC=
