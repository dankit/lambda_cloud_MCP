# Most people should run `npm run setup` instead of editing this by hand.
# It writes a validated .env.local for you. This file is the manual fallback.
#
# Copy to .env.local (or .env) in the project root. Next.js reads these for the
# UI; MCP loads the same files from process.cwd().
#
# Only the two REQUIRED vars below are needed for local development. Everything
# else has a sensible default — see docs/configuration.md for the full reference.

# --- Required ---

# Lambda Cloud API key: https://cloud.lambda.ai/api-keys
LAMBDA_API_KEY=

# Absolute path to the .pem matching your Lambda SSH public key.
LAMBDA_SSH_PEM_PATH=

# --- Agent transport (pick one) ---

# Poke (HTTP, recommended): MCP serves http://127.0.0.1:8080/mcp.
# Connect with: npx poke@latest tunnel http://127.0.0.1:8080/mcp -n "Local dev mcp"
LAMBDA_MCP_TRANSPORT=http

# Cursor / editor (stdio): comment out the line above (stdio is the default
# when LAMBDA_MCP_TRANSPORT is unset); your editor launches `npm run mcp`.

# Advanced settings (Poke notify, watch/snipe sync, SSH tuning, training hints,
# production deployment): see docs/configuration.md
