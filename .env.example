# =============================================================================
# Lambda Cloud + Poke — core (Next.js reads .env / .env.local on the dev server.)
# MCP: set the same Lambda key (and PEM/SSH/watch URL) where the MCP host runs.
# =============================================================================

# Authenticates server-side Lambda API calls when the UI/API key isn’t overridden.
LAMBDA_API_KEY=

# If set, after a successful launch the app POSTs launch details to Poke (Kitchen V2 API).
POKE_API_KEY=

# =============================================================================
# SSH PEM (browser UI suggestion + MCP remote exec)
# =============================================================================

# Absolute or relative path to the .pem for a public key registered in Lambda.
# - UI uses it only to show a suggested ssh -i … command (nothing is uploaded to Lambda).
# - MCP tool lambda_ssh_exec needs it so the MCP process can SSH to instances.

# LAMBDA_SSH_PEM_PATH=

# =============================================================================
# MCP SSH — connection options for lambda_ssh_exec only
# Omit these to use baked-in defaults (see src/lib/mcp-ssh.ts).
# =============================================================================

# LAMBDA_SSH_USER=ubuntu
# LAMBDA_SSH_PORT=22
# LAMBDA_SSH_TIMEOUT_MS=120000
# LAMBDA_SSH_DISABLE_HOST_KEY_CHECKING=true

# =============================================================================
# MCP training hints — text shown to agents, not executed here
# Set on the MCP process. Non-empty values appear in lambda_ssh_list_training_hints JSON.
# This server never runs them as shell; an agent chooses whether to reuse them via lambda_ssh_exec.
# Names: docs/mcp-ssh-training-hints.md

# MCP_ENV_SETUP_COMMAND=
# MCP_TRAINING_START_COMMAND=
# MCP_TRAINING_STATUS_COMMAND=
# MCP_TRAINING_LOG_PATH=

# =============================================================================
# Alerts & Snipe — persist to disk and expose over HTTP from Next
# Development NODE_ENV: if unset the app uses cwd/.lambda/watch-config.json (ignored by git).
# Production: set explicitly (otherwise /api/watch-config returns 503 and UI uses local alerts only.)
# =============================================================================

# Override JSON path for GET /api/watch-config + POST sync (still debounced).
# Leave unset locally to keep the automatic dev default above.
# LAMBDA_WATCH_CONFIG_PATH=

# MCP only: HTTP GET URL to load the same alerts/snipe (typically your running Next app), e.g.:
#   http://127.0.0.1:3000/api/watch-config
# MCP does not open the disk path above; it always loads watch state through this fetch.
# LAMBDA_WATCH_HTTP_URL=

# =============================================================================
# Securing /api/watch-config and production gating
# Development NODE_ENV: watch-config routes work without LAMBDA_WATCH_ALLOW_SYNC.
# Setting LAMBDA_WATCH_CONFIG_SYNC_SECRET still requires matching x-lambda-watch-sync-secret.
# =============================================================================

# If set, GET/POST /api/watch-config require header x-lambda-watch-sync-secret to match.
# LAMBDA_WATCH_CONFIG_SYNC_SECRET=

# Same value bundled to the browser (NEXT_PUBLIC_*) so the UI can POST with the secret.
# Needed only when LAMBDA_WATCH_CONFIG_SYNC_SECRET is set — avoid exposing on public deployments.
# NEXT_PUBLIC_LAMBDA_WATCH_SYNC_SECRET=

# MCP-only override: header sent when MCP GETs LAMBDA_WATCH_HTTP_URL; defaults to sync secret above.
# LAMBDA_WATCH_HTTP_SYNC_SECRET=

# In production NODE_ENV, allow GET/POST /api/watch-config only when explicitly "true".
# Local dev does not require this.

# LAMBDA_WATCH_ALLOW_SYNC=
